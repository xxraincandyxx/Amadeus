# Provider selection (anthropic or openai, default: anthropic)
PROVIDER=anthropic

# Anthropic API Key (required if provider=anthropic)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# Anthropic Base URL (optional, for API proxies)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI API Key (required if provider=openai)
OPENAI_API_KEY=sk-proj-xxx

# OpenAI Base URL (optional, for API proxies)
# OPENAI_BASE_URL=https://api.openai.com

# Model ID (optional, provider-specific defaults)
# Anthropic examples: claude-sonnet-4-5-20250929, claude-opus-4-5-20250929, claude-haiku-4-5-20250929
# OpenAI examples: gpt-4, gpt-4-turbo, gpt-3.5-turbo, gpt-4o, gpt-4o-mini
MODEL_ID=claude-sonnet-4-5-20250929


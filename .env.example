# Amadeus environment configuration example.
# Copy to `.env` (gitignored) and fill in real values. Never commit real keys.
# The Rust SDK reads JSON config from `.amadeus/settings.json`; this `.env` is
# consumed by the Python tooling under `experiments/` and `runtime/`.

# ---- Provider ----
PROVIDER=openai            # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- OpenAI-compatible / self-hosted endpoint (experiments & benchmarks) ----
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=
LLM_API_KEY=

# ---- Runtime ----
RUST_LOG=info
TIMEOUT_SECONDS=120

# ---- Long-context benchmark (runtime/locomo) ----
LOCOMO_BASE_URL=http://localhost:8080/v1
LOCOMO_API_KEY=
LOCOMO_JUDGE_BASE_URL=http://localhost:8080/v1
LOCOMO_JUDGE_API_KEY=

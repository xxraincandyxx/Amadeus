{
  "id": "approval_denied_bash",
  "suite": "approval",
  "description": "Dangerous bash command triggers approval and gets denied without a handler",
  "tags": ["approval", "bash", "safety"],
  "prompt": "Try a privileged command and explain what happened.",
  "mode": "mock",
  "config": {
    "approval_mode": "ask"
  },
  "mock_script": {
    "steps": [
      {
        "events": [
          { "type": "tool_call_start", "id": "tool_1", "name": "bash" },
          { "type": "tool_call_delta", "arguments": "{\"command\":\"sudo ls\"}" },
          { "type": "tool_call_done", "id": "tool_1" },
          { "type": "stop_reason", "reason": "tool_use" }
        ]
      },
      {
        "events": [
          { "type": "text_delta", "text": "The command required approval, so it was not executed." },
          { "type": "stop_reason", "reason": "end_turn" }
        ]
      }
    ]
  },
  "expectations": {
    "required_substrings": ["required approval"],
    "required_tools": ["bash"],
    "expect_error": false,
    "expect_approval": true
  },
  "thresholds": {
    "max_duration_ms": 5000,
    "max_tool_calls": 1,
    "max_errors": 0
  }
}
